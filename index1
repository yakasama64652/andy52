<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Great Library | Knowledge Base</title>
    <style>
        :root {
            --primary: #2c3e50;
            --accent: #3498db;
            --bg: #f4f7f6;
            --text: #333;
            --white: #ffffff;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            line-height: 1.6;
        }

        /* Navigation */
        nav {
            background: var(--primary);
            color: var(--white);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo { font-size: 1.5rem; font-weight: bold; }

        /* Hero Section */
        header {
            text-align: center;
            padding: 4rem 1rem;
            background: linear-gradient(rgba(44, 62, 80, 0.9), rgba(44, 62, 80, 0.9)), 
                        url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1000&q=80');
            background-size: cover;
            color: white;
        }

        .search-container {
            margin-top: 20px;
        }

        #knowledgeSearch {
            padding: 12px 25px;
            width: 300px;
            border-radius: 25px;
            border: none;
            font-size: 1rem;
            outline: none;
        }

        /* Knowledge Grid */
        .container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1rem;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .card {
            background: var(--white);
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
            border-top: 5px solid var(--accent);
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card h3 {
            margin-top: 0;
            color: var(--primary);
        }

        .tag {
            background: #e1f5fe;
            color: #0288d1;
            padding: 4px 10px;
            border-radius: 15px;
            font-size: 0.8rem;
            text-transform: uppercase;
        }

        footer {
            text-align: center;
            padding: 2rem;
            background: var(--primary);
            color: white;
            margin-top: 3rem;
        }
    </style>
</head>
<body>

    <nav>
        <div class="logo">🏛️ KnowledgeLib</div>
        <div>Home | Categories | Archives</div>
    </nav>

    <header>
        <h1>Universal Library of Knowledge</h1>
        <p>Exploring the depths of human understanding, one byte at a time.</p>
        <div class="search-container">
            <input type="text" id="knowledgeSearch" placeholder="Search a topic..." onkeyup="filterLibrary()">
        </div>
    </header>

    <div class="container" id="libraryGrid">
        <div class="card">
            <span class="tag">Science</span>
            <h3>Quantum Entanglement</h3>
            <p>A physical phenomenon that occurs when pairs or groups of particles are generated, interact, or share spatial proximity.</p>
            <a href="#">Read more →</a>
        </div>

        <div class="card">
            <span class="tag">History</span>
            <h3>The Renaissance</h3>
            <p>A fervent period of European cultural, artistic, political and economic "rebirth" following the Middle Ages.</p>
            <a href="#">Read more →</a>
        </div>

        <div class="card">
            <span class="tag">Technology</span>
            <h3>Artificial Intelligence</h3>
            <p>The simulation of human intelligence processes by machines, especially computer systems.</p>
            <a href="#">Read more →</a>
        </div>

        <div class="card">
            <span class="tag">Philosophy</span>
            <h3>Stoicism</h3>
            <p>A school of Hellenistic philosophy that flourished in Ancient Greece and Ancient Rome for those who seek a calm life.</p>
            <a href="#">Read more →</a>
        </div>
    </div>

    <footer>
        <p>&copy; 2024 Knowledge Library Project. Keep learning.</p>
    </footer>

    <script>
        function filterLibrary() {
            let input = document.getElementById('knowledgeSearch').value.toLowerCase();
            let cards = document.getElementsByClassName('card');

            for (let i = 0; i < cards.length; i++) {
                let title = cards[i].getElementsByTagName('h3')[0].innerText.toLowerCase();
                let text = cards[i].getElementsByTagName('p')[0].innerText.toLowerCase();
                
                if (title.includes(input) || text.includes(input)) {
                    cards[i].style.display = "";
                } else {
                    cards[i].style.display = "none";
                }
            }
        }
    </script>
</body>
</html>
